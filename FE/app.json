{
  "expo": {
    "name": "Avus Wallet",
    "slug": "avus-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-white.png",
    "scheme": "avuswalletfe",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to use the camera",
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to your photo library to save and share images.",
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save images to your photo library.",
        "NSPushNotificationsUsageDescription": "Allow $(PRODUCT_NAME) to permission to send you notifications.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        },
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "UIViewControllerBasedStatusBarAppearance": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.avus.wallet"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-white.png",
        "backgroundColor": "#E6F4FE",
        "monochromeImage": "./assets/images/icon-white.png"
      },
      "permissions": [
        "INTERNET",
        "android.permission.CAMERA"
      ],
      "googleServicesFile": "./google-services.json",
      "package": "com.avus.wallet",
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon-white.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "imageWidth": 176,
          "dark": {
            "image": "./assets/images/icon-white.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use the microphone for FAN voice commands.",
          "speechRecognitionPermission": "Allow $(PRODUCT_NAME) to recognize speech for FAN voice commands."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera for secure identity verification.",
          "microphonePermission": false
        }
      ],
      "expo-sharing",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon-black.png",
          "color": "#347AF0",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "podfileProperties": {
              "use_modular_headers!": true
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4c30a04c-448b-4008-96fb-c8c5a4d7e8bd"
      }
    },
    "owner": "marveltech56"
  }
}